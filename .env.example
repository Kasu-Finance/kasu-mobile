# kasu-mobile environment (copy to `.env`; values are inlined by Metro at build time)

# --- Privy (shared with the kasu-ui web app so users get the same embedded wallet) ---
# REQUIRED. Same value as the web app's NEXT_PUBLIC_PRIVY_APP_ID.
EXPO_PUBLIC_PRIVY_APP_ID=
# REQUIRED for native. Create a mobile "App client" in the Privy dashboard
# (App settings -> Clients) for bundle id `finance.kasu.mobile`, and allow the
# `kasumobile://` URL scheme. Paste the client id here.
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# --- Base RPC ---
# A dedicated Base RPC gateway (Tenderly/Alchemy/etc.). The SDK does many
# per-tranche on-chain reads for the portfolio; the public mainnet.base.org
# fallback is rate-limited and takes minutes. Leave blank to use the fallback.
EXPO_PUBLIC_BASE_RPC_URL=

# --- kasu-backend (NestJS) ---
# Default is correct for prod. Only used for KYC/contract calls — NOT needed for
# login + read-only portfolio.
EXPO_PUBLIC_KASU_API_BASE_URL=https://backend.kasu.finance
# Pool-delegate API key for protected backend routes (omit for login + portfolio).
EXPO_PUBLIC_KASU_API_KEY=

# --- Chain ---
# One of: base | xdc | xdc-usdc | plume
EXPO_PUBLIC_DEFAULT_CHAIN=base

# --- Demo ---
# OPTIONAL. When set, Home + Lend show THIS address's real Kasu positions
# (read-only) instead of the fresh login wallet's — so a TestFlight demo shows an
# actual lender portfolio. Leave blank to show the logged-in wallet's own positions.
EXPO_PUBLIC_DEMO_PORTFOLIO_ADDRESS=

# --- KYC (Compilot / Nexera) ---
# Hosted Compilot identity-verification URL loaded in the in-app WebView.
# TODO(compilot): confirm Compilot exposes a hosted/redirect flow that works in
# a bare WebView (the web app uses the @compilot/react-sdk iframe widget which
# needs an in-page wallet signature). Leave blank to show an "unavailable" state.
EXPO_PUBLIC_COMPILOT_KYC_URL=

# --- Wayex fiat on/off-ramp (F3) ---
# No client-side Wayex secrets: the app proxies every Wayex call through
# kasu-backend (`/wayex/*`), which holds the WAYEX_* secrets and signs the
# upstream requests. The session token is minted by the backend and stored in
# expo-secure-store (auto-attached as `x-wayex-session`). The v1 corridor is
# fixed server-side to USD/ACH → USDC on Base, so no extra env is required
# here. Listed for clarity / future per-corridor overrides.
