{
  "expo": {
    "name": "Kasu",
    "slug": "kasu",
    "owner": "kivanov82",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kasumobile",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "finance.kasu.mobile",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Kasu uses the camera to verify your identity when you set up your card.",
        "NSMicrophoneUsageDescription": "Kasu uses the microphone during identity verification."
      }
    },
    "android": {
      "package": "finance.kasu.mobile",
      "permissions": ["android.permission.CAMERA"],
      "adaptiveIcon": {
        "backgroundColor": "#1f1f24",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1f1f24",
          "image": "./assets/brand/splash-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "expo-image",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "6e85c6e8-e6f6-4410-94aa-4c1a12d724fd"
      }
    }
  }
}